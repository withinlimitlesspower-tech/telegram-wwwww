# Environment variables for Weather Telegram Bot
# Copy this to .env file and fill in your values
# Or set as Secrets in Replit

# Required: Get from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Required: Create bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Required: Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Defaults to Delhi, India
CITY=Delhi
COUNTRY_CODE=IN

# Optional: metric for Celsius, imperial for Fahrenheit
UNITS=metric

# Optional: Port for health check server (Replit uses this)
PORT=8000
